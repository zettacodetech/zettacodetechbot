# Majburiy obuna: 1 bo'lsa foydalanuvchi PROJECT_CHANNEL_USERNAME kanaliga obuna bo'lishi shart.
# Bot o'sha kanalda admin bo'lishi kerak. Xato bo'lsa fail-open (to'smaydi).
REQUIRE_SUBSCRIPTION=0
WEBAPP_AUTH_MAX_AGE=86400
WEBAPP_ALLOW_LOCAL_TEST=1
REMINDER_AFTER_HOURS=3
DAILY_REPORT_HOUR=20
WEB_ADMIN_ENABLED=1
WEB_ADMIN_HOST=127.0.0.1
WEB_ADMIN_PORT=8088
WEB_ADMIN_TOKEN=change_this_token
# Ma'lumotlar bazasi: DATABASE_URL bo'lsa PostgreSQL, bo'lmasa SQLite (DB_PATH) ishlatiladi.
# Railwayda: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
DB_PATH=orders.db
# Redis bo'lsa sessiya va rate-limit Redis'da saqlanadi (restartda yo'qolmaydi).
# Railwayda: REDIS_URL=${{Redis.REDIS_URL}}
REDIS_URL=
